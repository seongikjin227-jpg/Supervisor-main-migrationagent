# Copy this file to .env and fill in values for your environment.
# Windows PowerShell: Copy-Item .env.example .env

# =============================================================================
# Required
# =============================================================================

# Oracle DB connection
DB_USER=
DB_PASS=
DB_HOST=localhost
DB_PORT=1521
DB_SID=xe

# LLM
# LLM_PROVIDER must be openai or anthropic.
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# RAG embedding is required when SQL tuning uses the rule catalog.
RAG_EMBED_BASE_URL=
RAG_EMBED_API_KEY=
RAG_EMBED_MODEL=bge-m3

# SQL tuning rule catalog
TOBE_RULE_CATALOG_PATH=server/services/sql/data/rag/tobe_rule_catalog.json
UNIVERSAL_TUNING_RULES_PATH=server/services/sql/data/rules/universal_tuning_rules.json

# Required only when running the MyBatis XML parser.
MAPPER_XML_SOURCE_DIR=
ACTIVE_SQL_ID_TABLE=

# =============================================================================
# Optional
# =============================================================================

# Oracle optional settings
# Set when using Oracle Client thick mode.
ORACLE_CLIENT_PATH=
# Prefixes unqualified table names when set.
ORACLE_SCHEMA=

# Target table names
MAPPING_RULE_TABLE=NEXT_MIG_INFO
MAPPING_RULE_DETAIL_TABLE=NEXT_MIG_INFO_DTL
RESULT_TABLE=NEXT_SQL_INFO

# LLM optional settings
# Legacy alias used by some dashboard/init code. Usually leave blank if LLM_API_KEY is set.
OPEN_API_KEY=
# Use for a custom OpenAI-compatible endpoint. Leave blank for the provider default.
LLM_BASE_URL=
# Maximum output tokens for LLM responses. Must be a number.
LLM_MAX_TOKENS=4096

# RAG and SQL tuning options
RAG_EMBED_TIMEOUT_SEC=30
TOBE_SQL_TUNING_TOP_K=3
TOBE_SQL_TUNING_MAX_ITERATIONS=1

# MyBatis XML parser options
XML_PARSER_DATA_DIR=server/services/sql/DATA
ACTIVE_SQL_ID_COLUMN=SQL_ID

# Supervisor options
PLANNER_ENABLED=true
PLANNER_MAX_MIG_PER_CYCLE=5
# LangGraph node transition limit for the long-running Supervisor loop.
SUPERVISOR_RECURSION_LIMIT=10000
MIG_KIND=DB_MIG
